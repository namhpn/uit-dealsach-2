CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
# Comma-separated allowed frontend origins for credentialed requests.
cors.allowedOrigins = http://localhost:5173,https://dealsach.eu.cc

#--------------------------------------------------------------------
# DATABASE (CodeIgniter runtime)
#--------------------------------------------------------------------
database.default.hostname = db
database.default.database = dealsach_db
database.default.username = dealsach_user
database.default.password = change_me_db_password
database.default.DBDriver = MySQLi
database.default.port = 3306

#--------------------------------------------------------------------
# DATABASE (Docker Compose interpolation keys)
#--------------------------------------------------------------------
database_default_hostname = db
database_default_database = dealsach_db
database_default_username = dealsach_user
database_default_password = change_me_db_password
database_root_password = change_me_root_password
